{
  "contract": "RuntimeConfig",
  "producer": "M2",
  "consumers": ["M3", "M4", "M5", "M6"],
  "tenant_id": "tenant_demo",
  "profile": "local_minio_spark_smoke",
  "runner": {
    "default": "local_runner",
    "allowed": ["local_runner", "spark_runner"],
    "spark_select_rule": "M5 selects spark_runner only when runtime_config.runner is spark and Spark smoke has passed"
  },
  "spark_runner_smoke": {
    "runner": "spark_runner",
    "input_format": "jsonl",
    "input_path": "backend/samples/amazon_reviews_demo.jsonl",
    "output_format": "parquet",
    "output_root": "data/week2",
    "result_fields": ["status", "row_count", "bytes", "duration_ms", "output_path"]
  },
  "product_health_runtime_smoke": {
    "runner": "spark_runner",
    "source_inputs": [
      {
        "source_id": "reviews_seed",
        "input_format": "jsonl",
        "input_path": "backend/samples/product_health_reviews_seed.jsonl"
      },
      {
        "source_id": "behavior_events_seed",
        "input_format": "jsonl",
        "input_path": "backend/samples/product_health_behavior_events_seed.jsonl"
      },
      {
        "source_id": "delivery_trips_seed",
        "input_format": "jsonl",
        "input_path": "backend/samples/product_health_delivery_trips_seed.jsonl"
      },
      {
        "source_id": "product_master_seed",
        "input_format": "jsonl",
        "input_path": "backend/samples/product_health_product_master_seed.jsonl"
      }
    ],
    "output_format": "parquet",
    "output_root": "data/week2",
    "options": {
      "output_file_name_template": "{source_id}.parquet"
    },
    "result_fields": ["status", "row_count", "bytes", "duration_ms", "output_path", "task_results"],
    "ownership_note": "M2 pass-through runtime evidence only; M3 owns Bronze/Silver/Gold TransformSpec semantics."
  },
  "l6_preview_runtime_smoke": {
    "runner": "spark_runner",
    "input_format": "jsonl",
    "input_path": "backend/samples/product_health_reviews_seed.jsonl",
    "output_format": "parquet",
    "output_root": "data/week2",
    "transform_spec": {
      "artifact_type": "silver_transform_spec",
      "write_mode": "preview_only",
      "operations": [
        {
          "operation_id": "select_product_review_fields",
          "operation": "select",
          "params": {
            "columns": ["product_id", "rating", "review_text"]
          }
        },
        {
          "operation_id": "cast_rating",
          "operation": "cast",
          "params": {
            "source_path": "rating",
            "target_type": "number"
          }
        }
      ]
    },
    "options": {
      "output_file_name": "silver_preview.parquet"
    },
    "supported_operations": ["select", "rename", "cast", "parse_timestamp", "normalize_null", "json_string", "mask", "drop", "aggregate"],
    "unsupported_operation_rule": "return failed Week2RunnerResult instead of silently succeeding",
    "ownership_note": "M3 owns L6 TransformSpec semantics; M2 only executes preview-compatible operations and records evidence."
  },
  "storage": {
    "profile": "minio",
    "bucket": "asklake-demo",
    "endpoint": "http://localhost:9000",
    "region": "us-east-1",
    "prefix": "reviews/gold/run_id=<run_id>/",
    "path_pattern": "s3://<bucket>/<domain>/<layer>/[dataset_path/]run_id=<run_id>/",
    "local_fallback_root": "data/week2",
    "access_key_env": "ASKLAKE_DEMO_MINIO_ACCESS_KEY",
    "secret_key_env": "ASKLAKE_DEMO_MINIO_SECRET_KEY",
    "auto_create_bucket": true,
    "upload_timeout_seconds": 30,
    "path_contract_status": "object_upload_smoke_ready"
  },
  "spark": {
    "enabled_for_main_path": false,
    "app_name": "asklake-week2",
    "master": "local[*]",
    "smoke_required_before_runner": true,
    "config": {}
  },
  "parquet": {
    "format": "parquet",
    "compression": "snappy",
    "partitioning": ["run_id"]
  },
  "sql": {
    "engine": "duckdb",
    "default_limit": 100,
    "timeout_seconds": 30,
    "allow_tables": ["reviews_gold"]
  },
  "secrets": {
    "uses_secret_values": false,
    "secret_refs": [
      "ASKLAKE_DEMO_MINIO_ACCESS_KEY",
      "ASKLAKE_DEMO_MINIO_SECRET_KEY"
    ]
  },
  "updated_at": "2026-06-28T00:00:00+09:00"
}
