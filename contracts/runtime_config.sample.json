{
  "contract": "RuntimeConfig",
  "producer": "M2",
  "consumers": ["M3", "M4", "M5", "M6"],
  "tenant_id": "tenant_demo",
  "profile": "local_minio_spark_smoke",
  "runner": {
    "default": "local_runner",
    "allowed": ["local_runner", "spark_runner"],
    "spark_select_rule": "M5 selects spark_runner only when runtime_config.runner is spark and Spark smoke has passed"
  },
  "spark_runner_smoke": {
    "runner": "spark_runner",
    "input_format": "jsonl",
    "input_path": "backend/samples/amazon_reviews_demo.jsonl",
    "output_format": "parquet",
    "output_root": "data/week2",
    "result_fields": ["status", "row_count", "bytes", "duration_ms", "output_path"]
  },
  "product_health_runtime_smoke": {
    "runner": "spark_runner",
    "source_inputs": [
      {
        "source_id": "reviews_seed",
        "source_type": "local_file",
        "format": "jsonl",
        "path": "backend/samples/product_health_reviews_seed.jsonl",
        "input_format": "jsonl",
        "input_path": "backend/samples/product_health_reviews_seed.jsonl"
      },
      {
        "source_id": "behavior_events_seed",
        "source_type": "local_file",
        "format": "jsonl",
        "path": "backend/samples/product_health_behavior_events_seed.jsonl",
        "input_format": "jsonl",
        "input_path": "backend/samples/product_health_behavior_events_seed.jsonl"
      },
      {
        "source_id": "delivery_trips_seed",
        "source_type": "local_file",
        "format": "jsonl",
        "path": "backend/samples/product_health_delivery_trips_seed.jsonl",
        "input_format": "jsonl",
        "input_path": "backend/samples/product_health_delivery_trips_seed.jsonl"
      },
      {
        "source_id": "product_master_seed",
        "source_type": "local_file",
        "format": "jsonl",
        "path": "backend/samples/product_health_product_master_seed.jsonl",
        "input_format": "jsonl",
        "input_path": "backend/samples/product_health_product_master_seed.jsonl"
      }
    ],
    "source_input_contract": {
      "source_type": "where the source lives or how it is reached; current runner executes local_file only",
      "format": "data shape for file/message payloads such as json, jsonl, or parquet",
      "path": "preferred local_file path field",
      "legacy_fields": ["input_format", "input_path"],
      "unsupported_source_types_for_current_runner": ["s3", "postgres", "mongodb", "kafka"]
    },
    "output_format": "parquet",
    "output_root": "data/week2",
    "options": {
      "output_file_name_template": "{source_id}.parquet"
    },
    "result_fields": ["status", "row_count", "bytes", "duration_ms", "output_path", "task_results"],
    "ownership_note": "M2 pass-through runtime evidence only; M3 owns Bronze/Silver/Gold TransformSpec semantics."
  },
  "l6_preview_runtime_smoke": {
    "runner": "spark_runner",
    "input_format": "jsonl",
    "input_path": "backend/samples/product_health_reviews_seed.jsonl",
    "output_format": "parquet",
    "output_root": "data/week2",
    "transform_spec": {
      "artifact_type": "silver_transform_spec",
      "write_mode": "preview_only",
      "operations": [
        {
          "operation_id": "select_product_review_fields",
          "operation": "select",
          "params": {
            "columns": ["product_id", "rating", "review_text"]
          }
        },
        {
          "operation_id": "cast_rating",
          "operation": "cast",
          "params": {
            "source_path": "rating",
            "target_type": "number"
          }
        }
      ]
    },
    "options": {
      "output_file_name": "silver_preview.parquet"
    },
    "supported_operations": [
      "select",
      "rename",
      "cast",
      "parse_timestamp",
      "normalize_null",
      "flatten_struct",
      "explode_array",
      "json_string",
      "mask",
      "hash",
      "drop",
      "quarantine_if_invalid",
      "aggregate"
    ],
    "unsupported_operation_rule": "return failed Week2RunnerResult instead of silently succeeding",
    "operation_parameter_rule": "hash requires hash_policy.algorithm=hmac_sha256 and a salt_secret_id env reference; quarantine_if_invalid requires a validation rule; explode_array is bounded by cardinality guard/default max output rows",
    "ownership_note": "M3 owns L6 TransformSpec semantics; M2 only executes preview-compatible operations and records evidence."
  },
  "product_health_l6_gold_preview_smoke": {
    "runner": "spark_runner",
    "input_format": "jsonl",
    "input_path": "backend/samples/product_health_reviews_seed.jsonl",
    "output_format": "parquet",
    "output_root": "data/results/m2_product_health_l6_evidence",
    "transform_spec_path": "backend/samples/product_health_l6_gold_generation_spec.json",
    "options": {
      "output_file_name": "gold_product_health.parquet"
    },
    "result_fields": ["status", "row_count", "bytes", "duration_ms", "output_path", "output_row_count", "output_bytes", "task_results"],
    "sql_smoke": {
      "engine": "duckdb",
      "table_name": "gold_product_health",
      "query": "SELECT product_id, review_count, average_rating FROM gold_product_health LIMIT 100",
      "expected_min_rows": 1
    },
    "scope_note": "Small Product Health L6 execution evidence. This pairs with product_health_runtime_smoke source_inputs[] evidence. Final negative_review_rate/conversion_rate/late_delivery_rate/risk_score semantics remain M3-owned."
  },
  "storage": {
    "profile": "minio",
    "bucket": "asklake-demo",
    "endpoint": "http://localhost:9000",
    "region": "us-east-1",
    "prefix": "reviews/gold/run_id=<run_id>/",
    "path_pattern": "s3://<bucket>/<domain>/<layer>/[dataset_path/]run_id=<run_id>/",
    "local_fallback_root": "data/week2",
    "access_key_env": "ASKLAKE_DEMO_MINIO_ACCESS_KEY",
    "secret_key_env": "ASKLAKE_DEMO_MINIO_SECRET_KEY",
    "auto_create_bucket": true,
    "upload_timeout_seconds": 30,
    "path_contract_status": "object_upload_smoke_ready"
  },
  "spark": {
    "enabled_for_main_path": false,
    "app_name": "asklake-week2",
    "master": "local[*]",
    "smoke_required_before_runner": true,
    "config": {}
  },
  "parquet": {
    "format": "parquet",
    "compression": "snappy",
    "partitioning": ["run_id"]
  },
  "sql": {
    "engine": "duckdb",
    "default_limit": 100,
    "timeout_seconds": 30,
    "allow_tables": ["reviews_gold"]
  },
  "secrets": {
    "uses_secret_values": false,
    "secret_refs": [
      "ASKLAKE_DEMO_MINIO_ACCESS_KEY",
      "ASKLAKE_DEMO_MINIO_SECRET_KEY"
    ]
  },
  "updated_at": "2026-06-28T00:00:00+09:00"
}
