{
  "contract": "KafkaTopicContract",
  "producer": "M4",
  "consumers": ["M3", "M5"],
  "tenant_id": "tenant_demo",
  "source_id": "source_kafka_reviews_events_demo",
  "topic": "asklake.reviews.raw_events",
  "event_key": "event_id",
  "event_time_column": "event_time",
  "event_shape": {
    "event_id": "string",
    "event_time": "timestamp",
    "event_type": "string",
    "payload": "object"
  },
  "replay": {
    "command": "python scripts/kafka_replay_to_parquet_demo.py",
    "rate_per_second": 1000,
    "source_file": "demo-output/replay-samples/sample-65536-bytes.csv"
  },
  "evidence": {
    "contract": "KafkaReplayEvidence",
    "metrics": ["sent_rows", "throughput_per_second", "error_count", "progress_percent", "duration_ms"],
    "output_path": "data/results/week2/_metadata/kafka_replay/<run_id>.json",
    "latest_path": "data/results/week2/_metadata/kafka_replay/latest.json",
    "backend_routes": [
      "GET /api/week2/kafka-replay/health",
      "GET /api/week2/kafka-replay/runs",
      "GET /api/week2/kafka-replay/runs/{run_id}"
    ],
    "lineage": ["source_file", "kafka_topic", "source_ref", "target_ref"],
    "kafka_ui_metrics": ["message_count", "consumer_lag", "throughput_per_second"],
    "main_path_blocker": false
  },
  "handoff": {
    "m3_uses_raw_event_contract": true,
    "m5_records_evidence_only_until_gold_path_exists": true
  },
  "updated_at": "2026-06-28T00:00:00+09:00"
}
