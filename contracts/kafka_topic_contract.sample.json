{
  "contract": "KafkaTopicContract",
  "producer": "M4",
  "consumers": ["M3", "M5"],
  "tenant_id": "tenant_demo",
  "source_id": "source_kafka_reviews_events_demo",
  "topic": "asklake.reviews.raw_events",
  "event_key": "event_id",
  "event_time_column": "event_time",
  "event_shape": {
    "event_id": "string",
    "user_id": "string",
    "event_time": "timestamp",
    "event_type": "string",
    "amount": "number",
    "payload": "object"
  },
  "replay": {
    "command": "POST http://localhost:5189/api/replay/start",
    "records_per_second": 10,
    "batch_size": 10,
    "partitions": 3,
    "start_row": 1,
    "max_rows": 5,
    "key_column": "event_id",
    "source_file": "backend/samples/kafka_replay_events.csv"
  },
  "evidence": {
    "metrics": ["message_count", "throughput_per_second", "consumer_lag", "error_count", "restart_result"],
    "output_path": "data/week2/kafka/raw_events/run_id=<run_id>/kafka_replay_evidence.json",
    "main_path_blocker": false
  },
  "handoff": {
    "m3_uses_raw_event_contract": true,
    "m5_records_evidence_only_until_gold_path_exists": true
  },
  "updated_at": "2026-06-26T00:00:00+09:00"
}
