apiVersion: eksctl.io/v1alpha5
kind: ClusterConfig

metadata:
  name: asklake-dev
  region: ap-northeast-2

iam:
  withOIDC: true

managedNodeGroups:
  - name: asklake-dev-ng
    instanceType: t3.small
    desiredCapacity: 1
    minSize: 1
    maxSize: 2
    volumeSize: 30
    labels:
      app: asklake
      env: dev
