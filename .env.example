# AskLake example environment values.
# Do not put real secrets in this file.

APP_ENV=local
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=000000000000
ECR_REPOSITORY_PREFIX=asklake
K8S_NAMESPACE=asklake-dev
AWS_ROLE_TO_ASSUME=arn:aws:iam::000000000000:role/asklake-github-actions-dev
AWS_PROFILE=asklake
EKS_CLUSTER_NAME=asklake-dev
GITHUB_REPOSITORY=JUNGLE-TEAM1/NMM_team1

# Week2 local Airflow smoke values.
# These are local demo credentials only; do not commit real Airflow credentials.
AIRFLOW_UID=50000
AIRFLOW_PORT=8080
ASKLAKE_WEEK2_AIRFLOW_BASE_URL=http://localhost:8080
ASKLAKE_WEEK2_AIRFLOW_DAG_ID=asklake_week2_reviews
ASKLAKE_WEEK2_AIRFLOW_USERNAME=airflow
ASKLAKE_WEEK2_AIRFLOW_PASSWORD=airflow
ASKLAKE_WEEK2_AIRFLOW_RESULT_ROOT=data/week2/_airflow_results
ASKLAKE_WEEK2_AIRFLOW_MAX_POLLS=20
ASKLAKE_WEEK2_AIRFLOW_POLL_INTERVAL_SECONDS=1
