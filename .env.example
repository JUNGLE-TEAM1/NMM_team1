# AskLake example environment values.
# Do not put real secrets in this file.

APP_ENV=local
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=000000000000
ECR_REPOSITORY_PREFIX=asklake
K8S_NAMESPACE=asklake-dev
AWS_ROLE_TO_ASSUME=arn:aws:iam::000000000000:role/asklake-github-actions-dev
AWS_PROFILE=asklake
EKS_CLUSTER_NAME=asklake-dev
GITHUB_REPOSITORY=JUNGLE-TEAM1/NMM_team1

# Week2 local LLM adapter values.
# Copy these values to .env.local and put real secrets there only.
WEEK2_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30

# Week2 local Airflow smoke values.
# These are local demo credentials only; do not commit real Airflow credentials.
AIRFLOW_UID=50000
AIRFLOW_PORT=8080
ASKLAKE_WEEK2_AIRFLOW_BASE_URL=http://localhost:8080
ASKLAKE_WEEK2_AIRFLOW_DAG_ID=asklake_week2_reviews
ASKLAKE_WEEK2_AIRFLOW_USERNAME=airflow
ASKLAKE_WEEK2_AIRFLOW_PASSWORD=airflow
ASKLAKE_WEEK2_AIRFLOW_RESULT_ROOT=data/week2/_airflow_results
ASKLAKE_WEEK2_AIRFLOW_MAX_POLLS=20
ASKLAKE_WEEK2_AIRFLOW_POLL_INTERVAL_SECONDS=1

# M4 Kafka replay local values.
# These values configure local replay evidence and failure-row storage only.
KAFKA_REPLAY_PORT=5189
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_UI_URL=http://localhost:8084
KAFKA_REPLAY_FULL_COUNT_MAX_BYTES=67108864
KAFKA_REPLAY_EVIDENCE_DIR=data/results/week2/_metadata/kafka_replay
KAFKA_REPLAY_DEAD_LETTER_DIR=data/results/week2/_metadata/kafka_replay/dead-letter
KAFKA_REPLAY_EVIDENCE_RETENTION_DAYS=7
KAFKA_LOG_RETENTION_HOURS=168

# Local Taxi PostgreSQL source registration smoke values.
# These are local demo values only; do not commit real database credentials.
ASKLAKE_TAXI_POSTGRES_HOST=localhost
ASKLAKE_TAXI_POSTGRES_PORT=55432
ASKLAKE_TAXI_POSTGRES_DATABASE=taxi_postgre
ASKLAKE_TAXI_POSTGRES_USERNAME=asklake
ASKLAKE_TAXI_POSTGRES_PASSWORD=asklake
ASKLAKE_TAXI_POSTGRES_TABLE=public.yellow_taxi_trips
